{
  "identifier": "default",
  "description": "Paste Canvas default capabilities",
  "windows": ["main", "window-*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:webview:allow-create-webview-window",
    "dialog:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    }
  ]
}
