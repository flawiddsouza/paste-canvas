{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paste Canvas",
  "version": "0.1.0",
  "identifier": "dev.pastecanvas.app",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "beforeBuildCommand": "bun run build:vite",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paste Canvas",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
